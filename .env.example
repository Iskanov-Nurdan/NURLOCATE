DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgres://pettrack:pettrack@db:5432/pettrack
REDIS_URL=redis://redis:6379/0
USE_REDIS=0
CORS_ALLOWED_ORIGINS=http://localhost:5173
DEVICE_OFFLINE_THRESHOLD_SECONDS=600

# Email (оставьте пустым для вывода в консоль)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@pettrack.example

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CURRENCY=usd
STRIPE_SUCCESS_URL=http://localhost:5173/billing?success=1
STRIPE_CANCEL_URL=http://localhost:5173/billing?cancelled=1

# Firebase FCM (путь к JSON-ключу сервисного аккаунта)
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1234567890

# OTA Firmware
LATEST_FIRMWARE_VERSION=1.0.0
FIRMWARE_DOWNLOAD_URL=https://firmware.pettrack.example/latest.bin
FIRMWARE_SHA256=

